{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/v1/:path*",
            "destination": "api/index.py"
        },
        {
            "source": "/(.*)",
            "destination": "frontend/$1"
        }
    ],
    "functions": {
        "api/index.py": {
            "runtime": "python3.12"
        }
    }
}