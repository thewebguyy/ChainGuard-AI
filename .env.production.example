# --- DEPLOYMENT INSTRUCTIONS ---
# 1. Create a Supabase project at https://supabase.com
# 2. Go to Project Settings -> Database -> Connection String -> URI
# 3. Use the "Transaction Pooler" URI (Port 6543)
# 4. Paste it below as SUPABASE_DATABASE_URL

SUPABASE_DATABASE_URL="postgres://postgres.your-project-id:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Vercel Configuration
JWT_SECRET="generate-a-random-secret-string"
API_V1_STR="/api/v1"

# External APIs (Optional)
NEWS_API_KEY=""
AFTERSHIP_API_KEY=""
